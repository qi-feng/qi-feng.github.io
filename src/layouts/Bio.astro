---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../config";
import { format } from "date-fns";

export interface Props {
	content: {
		title: string;
		description: string;
		pubDate?: string;
		updatedDate?: string;
		heroImage?: string;
	};
}

const {
	content: { title, description, pubDate, updatedDate, heroImage },
} = Astro.props;

const pubDateISO = pubDate ? format(new Date(pubDate), "yyyy-MM-dd") : undefined;
const updatedDateParsed = updatedDate ? new Date(updatedDate) : undefined;
const updatedDateISO =
	updatedDateParsed && !isNaN(updatedDateParsed.getTime())
		? format(updatedDateParsed, "yyyy-MM-dd")
		: undefined;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
		<style>
			main p:first-child {
				color: var(--text-light);
				font-size: 1rem;
			}
		</style>
	</head>

	<body>
		<Header title={title} description={description} />
		<main id="main-content">
			{pubDate && pubDateISO && (
				<p>
					<time datetime={pubDateISO}>{pubDate}</time>
				</p>
			)}

			{updatedDate && (
				<p>
					Last updated on{" "}
					{updatedDateISO ? (
						<time datetime={updatedDateISO}>{updatedDate}</time>
					) : (
						updatedDate
					)}
				</p>
			)}

			<div class="nowrap">
				{heroImage && (
					<div class="circular--portrait">
						<img src={heroImage} alt={`Portrait for ${title}`} />
					</div>
				)}
				<slot />
			</div>
		</main>
		<Footer />
	</body>
</html>