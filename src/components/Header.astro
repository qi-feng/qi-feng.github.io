---
import HeaderLink from "./HeaderLink.astro";
import ThemeIcon from "./ThemeIcon.astro";

const { title, description } = Astro.props.frontmatter || Astro.props;
---

<a class="skip-link" href="#main-content">Skip to main content</a>

<header>
  <nav aria-label="Primary">
    <HeaderLink href="/">Home</HeaderLink>
    <HeaderLink href="/research">Research</HeaderLink>
    <HeaderLink href="/teaching">Teaching</HeaderLink>
    <HeaderLink href="/group">Group</HeaderLink>
    <HeaderLink href="/about">Bio</HeaderLink>
    <HeaderLink href="/news">News</HeaderLink>
    <HeaderLink href="/CV.pdf">CV</HeaderLink>
    <ThemeIcon />
  </nav>

  <h1>{title}</h1>
  {description && <p>{description}</p>}
</header>